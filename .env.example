# ============================================================
# Declutr — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# All variables are documented in docs/declutr_architecture_document.html
# ============================================================

# ─── Server ─────────────────────────────────────────────────
PORT=8080
ENV=development

# ─── Database ───────────────────────────────────────────────
# Postgres connection string
# Supabase: find under Project Settings → Database → Connection string
# Neon: find under Dashboard → Connection Details
DATABASE_URL=postgres://declutr:declutr@localhost:5432/declutr

# ─── Cache ──────────────────────────────────────────────────
# Upstash Redis URL (or local Redis)
REDIS_URL=redis://localhost:6379

# ─── Auth ───────────────────────────────────────────────────
# Signing secret for JWT tokens (use a long random string)
JWT_SECRET=change-me-to-a-long-random-secret

# ─── AI Providers ───────────────────────────────────────────
# At least one is required for AI features.
OPENAI_API_KEY=
GEMINI_API_KEY=

# ─── Storage ────────────────────────────────────────────────
# Cloudflare R2 (S3-compatible)
# Get from: Cloudflare Dashboard → R2 → Manage API Tokens
R2_BUCKET=declutr-assets
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_URL=

# ─── Frontend (Next.js) ─────────────────────────────────────
# Must be prefixed with NEXT_PUBLIC_ to be exposed to the browser
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_APP_NAME=Declutr
